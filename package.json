{
  "name": "my-blog",
  "private": true,
  "description": "Hugo blog + VPS chat proxy for Xiao K",
  "scripts": {
    "build:rag": "node scripts/build-rag.mjs",
    "wall:dev": "mkdir -p tmp && WALL_DB_PATH=./tmp/wall.db WALL_ADMIN_TOKEN=dev-token node server/wall-api.mjs",
    "chat:dev": "CHAT_API_PORT=18788 BIGMODEL_API_KEY=${BIGMODEL_API_KEY:-dev-key} RAG_VECTORS_URL=https://sujian.online/rag-vectors.json node server/chat-api.mjs",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:secret": "wrangler secret put DASHSCOPE_API_KEY"
  },
  "devDependencies": {
    "wrangler": "^3.99.0"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  }
}
